# Rails environment variables template for PulseDesk
#
# Copy this file to .env (gitignored) and fill in real values for local development.

# ---- LLM provider for AI ticket classification ----
# Provider: "openrouter" or "groq"
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-replace-me
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_TIMEOUT=20

# ---- Redis (Sidekiq, optional for local dev) ----
# REDIS_URL=redis://localhost:6379/0

# ---- App ----
RAILS_ENV=development
SECRET_KEY_BASE=replace_me_with_rails_secret_output