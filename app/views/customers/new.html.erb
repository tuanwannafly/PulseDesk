<h1 class="text-2xl font-semibold mb-6">New customer</h1>

<%= form_with model: @customer, local: true, class: 'card max-w-xl space-y-4' do |f| %>
  <div><%= f.label :name,  class: 'field-label' %><%= f.text_field  :name,  required: true, class: 'field-input' %></div>
  <div><%= f.label :email, class: 'field-label' %><%= f.email_field :email, required: true, class: 'field-input' %></div>
  <div><%= f.label :notes, class: 'field-label' %><%= f.text_area :notes, rows: 4, class: 'field-input' %></div>
  <div class="flex justify-end gap-2">
    <%= link_to 'Cancel', customers_path, class: 'btn-secondary' %>
    <%= f.submit 'Create', class: 'btn-primary' %>
  </div>
<% end %>