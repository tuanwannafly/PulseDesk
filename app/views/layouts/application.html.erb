<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>PulseDesk · <%= content_for(:title).presence || 'Support' %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Skip stylesheet_link_tag in test env to avoid Sprockets asset pipeline errors %>
    <% unless Rails.env.test? %>
      <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <% end %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <% if logged_in? %>
      <header class="bg-white border-b border-slate-200 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <span class="font-semibold text-indigo-600">PulseDesk</span>
          <nav class="flex gap-4 text-sm">
            <%= link_to 'Inbox', tickets_path, class: 'hover:text-indigo-600' %>
            <%= link_to 'Customers', customers_path, class: 'hover:text-indigo-600' %>
            <%= link_to 'Tags', tags_path, class: 'hover:text-indigo-600' %>
            <%= link_to 'Dashboard', dashboard_path, class: 'hover:text-indigo-600' %>
          </nav>
        </div>
        <div class="flex items-center gap-3 text-sm">
          <span><%= current_user.name %></span>
          <%= button_to 'Logout', logout_path, method: :delete, class: 'text-slate-500 hover:text-slate-800' %>
        </div>
      </header>
    <% end %>

    <main class="flex-1 p-6">
      <% if flash[:notice] %>
        <div class="mb-4 p-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-800 text-sm rounded"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>