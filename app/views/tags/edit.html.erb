<h1 class="text-2xl font-semibold mb-6">Edit tag</h1>

<%= form_with model: @tag, local: true, class: 'card max-w-md space-y-4' do |f| %>
  <div><%= f.label :name, class: 'field-label' %><%= f.text_field :name, required: true, class: 'field-input' %></div>
  <div><%= f.label :color, class: 'field-label' %><%= f.color_field :color, class: 'field-input h-10' %></div>
  <%= f.submit 'Save', class: 'btn-primary' %>
<% end %>