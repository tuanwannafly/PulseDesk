<% content_for :title, 'Tags' %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold">Tags</h1>
  <%= link_to 'New tag', new_tag_path, class: 'btn-primary' %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
  <% @tags.each do |t| %>
    <div class="card flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full" style="background: <%= t.color %>"></span>
        <span class="font-medium"><%= t.name %></span>
      </div>
      <div class="text-xs">
        <%= link_to 'Edit', edit_tag_path(t), class: 'text-slate-600 hover:underline mr-2' %>
        <%= button_to 'Delete', t, method: :delete, class: 'text-red-600 hover:underline',
                      data: { turbo_confirm: 'Delete tag?' } %>
      </div>
    </div>
  <% end %>
</div>