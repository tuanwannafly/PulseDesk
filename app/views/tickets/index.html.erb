<% content_for :title, 'Inbox' %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold">Inbox</h1>
  <%= link_to 'New ticket', new_ticket_path, class: 'btn-primary' %>
</div>

<div class="grid grid-cols-3 gap-3 mb-6">
  <div class="card text-center">
    <div class="text-xs uppercase text-slate-500">Open</div>
    <div class="text-2xl font-semibold text-indigo-600"><%= @stats[:open] %></div>
  </div>
  <div class="card text-center">
    <div class="text-xs uppercase text-slate-500">Pending</div>
    <div class="text-2xl font-semibold text-yellow-600"><%= @stats[:pending] %></div>
  </div>
  <div class="card text-center">
    <div class="text-xs uppercase text-slate-500">Resolved</div>
    <div class="text-2xl font-semibold text-green-600"><%= @stats[:resolved] %></div>
  </div>
</div>

<%= form_with url: tickets_path, method: :get, local: true,
              class: 'flex items-center gap-3 mb-4 text-sm' do |f| %>
  <%= f.select :status, [['All statuses', nil]] + Ticket::STATUSES.map { |s| [s.titleize, s] },
               { selected: @status_filter }, class: 'field-input max-w-xs' %>
  <%= f.select :priority, [['All priorities', nil]] + Ticket::PRIORITIES.map { |p| [p.titleize, p] },
               { selected: @priority_filter }, class: 'field-input max-w-xs' %>
  <%= f.submit 'Filter', class: 'btn-secondary' %>
<% end %>

<div class="card overflow-hidden p-0">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left">
      <tr class="text-xs uppercase tracking-wide text-slate-500">
        <th class="px-4 py-3">Subject</th>
        <th class="px-4 py-3">Customer</th>
        <th class="px-4 py-3">Status</th>
        <th class="px-4 py-3">Priority</th>
        <th class="px-4 py-3">Sentiment</th>
        <th class="px-4 py-3">Assigned</th>
        <th class="px-4 py-3">Created</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 bg-white">
      <% if @tickets.any? %>
        <% @tickets.each do |t| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <%= link_to t.subject, t, class: 'text-indigo-600 hover:underline font-medium' %>
              <% if t.ai_summary.present? %>
                <div class="text-xs text-slate-500 mt-0.5 line-clamp-1"><%= t.ai_summary %></div>
              <% end %>
            </td>
            <td class="px-4 py-3 text-slate-600"><%= t.customer.name %></td>
            <td class="px-4 py-3">
              <span class="badge bg-<%= t.status == 'open' ? 'indigo' : t.status == 'pending' ? 'yellow' : 'green' %>-100 text-<%= t.status == 'open' ? 'indigo' : t.status == 'pending' ? 'yellow' : 'green' %>-700">
                <%= t.status %>
              </span>
            </td>
            <td class="px-4 py-3">
              <span class="badge bg-<%= { 'urgent' => 'red', 'high' => 'orange', 'normal' => 'slate', 'low' => 'gray' }[t.priority] %>-100 text-<%= { 'urgent' => 'red', 'high' => 'orange', 'normal' => 'slate', 'low' => 'gray' }[t.priority] %>-700">
                <%= t.priority %>
              </span>
            </td>
            <td class="px-4 py-3">
              <% if t.sentiment_score %>
                <span class="badge bg-<%= t.sentiment_color %>-100 text-<%= t.sentiment_color %>-700">
                  <%= t.sentiment_label %> (<%= t.sentiment_score.round(2) %>)
                </span>
              <% else %>
                <span class="text-xs text-slate-400">pending</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-slate-600"><%= t.assigned_to&.name || '—' %></td>
            <td class="px-4 py-3 text-xs text-slate-500"><%= time_ago_in_words(t.created_at) %> ago</td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="7" class="px-4 py-10 text-center text-slate-400">No tickets match.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>