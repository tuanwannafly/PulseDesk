<% content_for :title, 'New ticket' %>

<h1 class="text-2xl font-semibold mb-6">New ticket</h1>

<%= form_with model: @ticket, local: true, class: 'card max-w-2xl space-y-4' do |f| %>
  <% if @ticket.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 text-sm rounded p-3">
      <ul class="list-disc pl-5">
        <% @ticket.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :subject, class: 'field-label' %>
    <%= f.text_field :subject, required: true, class: 'field-input' %>
  </div>

  <div>
    <%= f.label :customer_id, 'Customer', class: 'field-label' %>
    <%= f.collection_select :customer_id, Customer.order(:name), :id, :name,
                            { include_blank: '— select —' }, { class: 'field-input' } %>
  </div>

  <div>
    <%= f.label :body, 'Initial message', class: 'field-label' %>
    <%= f.text_area :body, rows: 5, required: true, class: 'field-input' %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :priority, class: 'field-label' %>
      <%= f.select :priority, Ticket::PRIORITIES.map { |p| [p.titleize, p] },
                   {}, class: 'field-input' %>
    </div>
    <div>
      <%= f.label :status, class: 'field-label' %>
      <%= f.select :status, Ticket::STATUSES.map { |s| [s.titleize, s] },
                   {}, class: 'field-input' %>
    </div>
  </div>

  <div>
    <%= f.label :tag_ids, 'Tags', class: 'field-label' %>
    <%= f.collection_check_boxes :tag_ids, Tag.order(:name), :id, :name do |b| %>
      <label class="inline-flex items-center mr-3 text-sm">
        <%= b.check_box(class: 'mr-1') %><%= b.text %>
      </label>
    <% end %>
  </div>

  <div class="flex justify-end gap-2">
    <%= link_to 'Cancel', tickets_path, class: 'btn-secondary' %>
    <%= f.submit 'Create ticket', class: 'btn-primary' %>
  </div>
<% end %>