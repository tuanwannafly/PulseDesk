<div class="max-w-md mx-auto card mt-10">
  <h1 class="text-xl font-semibold mb-4">Create your workspace</h1>

  <%= form_with model: @user, url: signup_path(subdomain: @account.subdomain), local: true, class: 'space-y-4' do |f| %>
    <%= hidden_field_tag :subdomain, @account.subdomain %>

    <div>
      <%= f.label :name, 'Your name', class: 'field-label' %>
      <%= f.text_field :name, required: true, class: 'field-input' %>
    </div>

    <div>
      <%= f.label :email, 'Email', class: 'field-label' %>
      <%= f.email_field :email, required: true, class: 'field-input' %>
    </div>

    <div>
      <%= f.label :password, class: 'field-label' %>
      <%= f.password_field :password, required: true, class: 'field-input' %>
    </div>

    <div>
      <%= f.label :password_confirmation, 'Confirm password', class: 'field-label' %>
      <%= f.password_field :password_confirmation, required: true, class: 'field-input' %>
    </div>

    <%= f.submit 'Create account', class: 'btn-primary w-full justify-center' %>
  <% end %>

  <p class="text-sm text-slate-600 mt-6 text-center">
    Already have an account?
    <%= link_to 'Sign in', login_path, class: 'text-indigo-600 hover:underline' %>
  </p>
</div>